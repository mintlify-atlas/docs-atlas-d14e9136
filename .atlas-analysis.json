  "keyFeatures": [
    "AI-powered sentiment analysis (positive/negative classification)",
    "Single comment analysis with confidence scores",
    "Bulk CSV upload for processing thousands of comments",
    "Real-time statistics dashboard with sentiment distribution",
    "Export analyzed results to CSV format",
    "Token-based authentication and session management",
    "Probability scores for each sentiment prediction"
  ],
  "publicApiSurface": [
    "POST /login - User authentication",
    "POST /sentiment - Analyze single or multiple comments",
    "POST /sentiment/upload-csv - Upload CSV file for bulk analysis",
    "POST /sentiment/export-csv - Export analysis results to CSV",
    "GET /stats - Retrieve sentiment statistics with pagination"
  ]
